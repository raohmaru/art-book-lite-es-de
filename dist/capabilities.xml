<themeCapabilities>
   
   <themeName>Art Book Lite</themeName>

   <!--
   ///
   Aspect Ratios
   ///
   -->
   <aspectRatio>16:9</aspectRatio>
   <aspectRatio>4:3</aspectRatio>

   <!--
   ///
   Font Size
   ///
   -->
   <fontSize>x-small</fontSize>
   <fontSize>small</fontSize>
   <fontSize>medium</fontSize>
   <fontSize>large</fontSize>
   <fontSize>x-large</fontSize>

   <!--
   ///
   Color Schemes
   ///
   -->
   <colorScheme name="dark-screenshots">
      <label>Dark [Screenshots]</label>
   </colorScheme>
   <colorScheme name="dark-outline">
      <label>Dark [Outline]</label>
   </colorScheme>
   <colorScheme name="light-screenshots">
      <label>Light [Screenshots]</label>
   </colorScheme>
   <colorScheme name="light-outline">
      <label>Light [Outline]</label>
   </colorScheme>
   <colorScheme name="steam-os-screenshots">
      <label>Steam OS [Screenshots]</label>
   </colorScheme>
   <colorScheme name="steam-os-outline">
      <label>Steam OS [Outline]</label>
   </colorScheme>
   <colorScheme name="snes-screenshots">
      <label>SNES [Screenshots]</label>
   </colorScheme>
   <colorScheme name="snes-outline">
      <label>SNES [Outline]</label>
   </colorScheme>
   <colorScheme name="famicom-screenshots">
      <label>Famicom [Screenshots]</label>
   </colorScheme>
   <colorScheme name="famicom-outline">
      <label>Famicom [Outline]</label>
   </colorScheme>
   <colorScheme name="custom">
      <label>Custom</label>
   </colorScheme>

   <!--
   ///
   Transitions
   ///
   -->
   <transitions name="slide">
      <label>Slide</label>
      <selectable>true</selectable>
      <systemToSystem>instant</systemToSystem>
      <systemToGamelist>slide</systemToGamelist>
      <gamelistToGamelist>slide</gamelistToGamelist>
      <gamelistToSystem>slide</gamelistToSystem>
      <startupToSystem>instant</startupToSystem>
      <startupToGamelist>instant</startupToGamelist>
   </transitions>
   <transitions name="instant">
      <label>Instant</label>
      <selectable>true</selectable>
      <systemToSystem>instant</systemToSystem>
      <systemToGamelist>instant</systemToGamelist>
      <gamelistToGamelist>instant</gamelistToGamelist>
      <gamelistToSystem>instant</gamelistToSystem>
      <startupToSystem>instant</startupToSystem>
      <startupToGamelist>instant</startupToGamelist>
   </transitions>
   <suppressTransitionProfiles>
      <entry>builtin-instant</entry>
      <entry>builtin-slide</entry>
      <entry>builtin-fade</entry>
   </suppressTransitionProfiles>

   <!--
   ///
   List Variants - Metadata & Media
   ///
   -->
   <!-- List: Metadata & Boxart -->
   <variant name="gamelist-list-metadata-cover">
      <label>List: Metadata &amp; Boxart</label>
      <selectable>true</selectable>
      <override>
         <trigger>noMedia</trigger>
         <mediaType>cover</mediaType>
         <useVariant>gamelist-list-basic</useVariant>
      </override>
   </variant>
   <!-- List: Metadata & Screenshot  -->
   <variant name="gamelist-list-metadata-screenshot">
      <label>List: Metadata &amp; Screenshot</label>
      <selectable>true</selectable>
      <override>
         <trigger>noMedia</trigger>
         <mediaType>screenshot</mediaType>
         <useVariant>gamelist-list-basic</useVariant>
      </override>
   </variant>
   <!-- List: Metadata & Screenshot + Marquee  -->
   <variant name="gamelist-list-metadata-screenshot-marquee">
      <label>List: Metadata &amp; Screenshot + Marquee</label>
      <selectable>true</selectable>
      <override>
         <trigger>noMedia</trigger>
         <mediaType>screenshot</mediaType>
         <useVariant>gamelist-list-basic</useVariant>
      </override>
   </variant>
   <!-- List: Metadata & Screenshot + Boxart  -->
   <variant name="gamelist-list-metadata-screenshot-cover">
      <label>List: Metadata &amp; Screenshot + Boxart</label>
      <selectable>true</selectable>
      <override>
         <trigger>noMedia</trigger>
         <mediaType>screenshot</mediaType>
         <useVariant>gamelist-list-basic</useVariant>
      </override>
   </variant>
   <!-- List: Metadata & Miximage -->
   <variant name="gamelist-list-metadata-miximage">
      <label>List: Metadata &amp; Miximage</label>
      <selectable>true</selectable>
      <override>
         <trigger>noMedia</trigger>
         <mediaType>miximage</mediaType>
         <useVariant>gamelist-list-basic</useVariant>
      </override>
   </variant>

   <!--
   ///
   List Variants - Media Only
   ///
   -->
   <!-- List: Boxart -->
   <variant name="gamelist-list-cover">
      <label>List: Boxart</label>
      <selectable>true</selectable>
      <override>
         <trigger>noMedia</trigger>
         <mediaType>cover</mediaType>
         <useVariant>gamelist-list-basic</useVariant>
      </override>
   </variant>
   <!-- List: Screenshot & Marquee -->
   <variant name="gamelist-list-screenshot-marquee">
      <label>List: Screenshot + Marquee</label>
      <selectable>true</selectable>
      <override>
         <trigger>noMedia</trigger>
         <mediaType>screenshot</mediaType>
         <useVariant>gamelist-list-basic</useVariant>
      </override>
   </variant>
   
   <!--
   ///
   List Variants - Basic
   ///
   -->
   <!-- List: Basic -->
   <variant name="gamelist-list-basic">
      <label>List</label>
      <selectable>true</selectable>
   </variant>
   
   <!--
   ///
   Grid Variants
   ///
   -->
   <!-- Grid: Default Covers -->
   <variant name="gamelist-grid-cover">
      <label>Grid: Boxart</label>
      <selectable>true</selectable>
   </variant>
   <!-- Grid: SteamGridDB Covers -->
   <variant name="gamelist-grid-cover-steamgriddb">
      <label>Grid: Boxart (SteamGridDB)</label>
      <selectable>true</selectable>
   </variant>
   <!-- Grid: Screenshots -->
   <variant name="gamelist-grid-screenshot">
      <label>Grid: Screenshot</label>
      <selectable>true</selectable>
   </variant>

   <!--
   ///
   NH List Variants - Metadata & Media
   ///
   -->
   <!-- NH List: Metadata & Boxart -->
   <variant name="gamelist-list-metadata-cover-nh">
      <label>[Help Off] List: Metadata &amp; Boxart</label>
      <selectable>true</selectable>
      <override>
         <trigger>noMedia</trigger>
         <mediaType>cover</mediaType>
         <useVariant>gamelist-list-basic-nh</useVariant>
      </override>
   </variant>
   <!-- NH List: Metadata & Screenshot -->
   <variant name="gamelist-list-metadata-screenshot-nh">
      <label>[Help Off] List: Metadata &amp; Screenshot</label>
      <selectable>true</selectable>
      <override>
         <trigger>noMedia</trigger>
         <mediaType>screenshot</mediaType>
         <useVariant>gamelist-list-basic-nh</useVariant>
      </override>
   </variant>
   <!-- NH List: Metadata & Screenshot + Marquee -->
   <variant name="gamelist-list-metadata-screenshot-marquee-nh">
      <label>[Help Off] List: Metadata &amp; Screenshot + Marquee</label>
      <selectable>true</selectable>
      <override>
         <trigger>noMedia</trigger>
         <mediaType>screenshot,marquee</mediaType>
         <useVariant>gamelist-list-basic-nh</useVariant>
      </override>
   </variant>
   <!-- NH List: Metadata & Screenshot + Boxart -->
   <variant name="gamelist-list-metadata-screenshot-cover-nh">
      <label>[Help Off] List: Metadata &amp; Screenshot + Boxart</label>
      <selectable>true</selectable>
      <override>
         <trigger>noMedia</trigger>
         <mediaType>screenshot</mediaType>
         <useVariant>gamelist-list-basic-nh</useVariant>
      </override>
   </variant>
   <!-- NH List: Metadata & Miximage -->
   <variant name="gamelist-list-metadata-miximage-nh">
      <label>[Help Off] List: Metadata &amp; Miximage</label>
      <selectable>true</selectable>
      <override>
         <trigger>noMedia</trigger>
         <mediaType>miximage</mediaType>
         <useVariant>gamelist-list-basic-nh</useVariant>
      </override>
   </variant>

   <!--
   ///
   NH List Variants - Media Only
   ///
   -->
   <!-- NH List: Boxart -->
   <variant name="gamelist-list-cover-nh">
      <label>[Help Off] List: Boxart</label>
      <selectable>true</selectable>
      <override>
         <trigger>noMedia</trigger>
         <mediaType>cover</mediaType>
         <useVariant>gamelist-list-basic-nh</useVariant>
      </override>
   </variant>
   <!-- NH List: Screenshot & Marquee -->
   <variant name="gamelist-list-screenshot-marquee-nh">
      <label>[Help Off] List: Screenshot + Marquee</label>
      <selectable>true</selectable>
      <override>
         <trigger>noMedia</trigger>
         <mediaType>screenshot,marquee</mediaType>
         <useVariant>gamelist-list-basic-nh</useVariant>
      </override>
   </variant>

   <!--
   ///
   NH List Variants - Basic
   ///
   -->
   <!-- NH List: Basic -->
   <variant name="gamelist-list-basic-nh">
      <label>[Help Off] List</label>
      <selectable>true</selectable>
   </variant>
   
   <!--
   ///
   NH Grid Variants
   ///
   -->
   <!-- Grid: Default Covers -->
   <variant name="gamelist-grid-cover-nh">
      <label>[Help Off] Grid: Boxart</label>
      <selectable>true</selectable>
   </variant>
   <!-- Grid: SteamGridDB Covers -->
   <variant name="gamelist-grid-cover-steamgriddb-nh">
      <label>[Help Off] Grid: Boxart (SteamGridDB)</label>
      <selectable>true</selectable>
   </variant>
   <!-- Grid: Screenshots -->
   <variant name="gamelist-grid-screenshot-nh">
      <label>[Help Off] Grid: Screenshot</label>
      <selectable>true</selectable>
   </variant>

</themeCapabilities>