        </variables>
    </colorScheme>
    <!-- artwork settings -->
    <colorScheme name="dark-screenshots,light-screenshots,steam-os-screenshots,snes-screenshots,famicom-screenshots,custom">
        <variables>
            <artworkSource>./_systems/artwork-screenshots</artworkSource>
            <artworkSourceDefault>${artworkSource}</artworkSourceDefault>
            <artworkDefaultImage>_default</artworkDefaultImage>
            <systemViewLogoPos>0.5 0.5</systemViewLogoPos>
        </variables>
    </colorScheme>
    <colorScheme name="dark-outline,light-outline,steam-os-outline,snes-outline,famicom-outline">
        <variables>
            <artworkSource>./_systems/artwork-outline</artworkSource>
            <artworkSourceDefault>${artworkSource}</artworkSourceDefault>
            <artworkDefaultImage>_default</artworkDefaultImage>
            <systemViewLogoPos>0.5 0.33</systemViewLogoPos>
        </variables>
    </colorScheme>
    <colorScheme name="custom">
        <variables>
            <customizationPath>./theme-customizations/customizations.xml</customizationPath>
            <artworkDefaultImage>${system.theme}</artworkDefaultImage>
        </variables>
    </colorScheme>
    <include>${customizationPath}</include>
</theme>