            <gamelistListTextlistBackgroundColor>eeeeeeff</gamelistListTextlistBackgroundColor>
            <gamelistListTextlistSelectedColor>ffffff</gamelistListTextlistSelectedColor>
            <gamelistListTextlistSelectedBackgroundColor>111111</gamelistListTextlistSelectedBackgroundColor>
            <gamelistListTextlistUnselectedColor>444444</gamelistListTextlistUnselectedColor>
            <gamelistListMetadataColor>000000</gamelistListMetadataColor>
            <gamelistListMetadataIconColor>00000077</gamelistListMetadataIconColor>
