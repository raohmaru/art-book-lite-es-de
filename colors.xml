            <gamelistListTextlistSelectedColor>DCD6B6</gamelistListTextlistSelectedColor>
            <gamelistListTextlistSelectedBackgroundColor>090203</gamelistListTextlistSelectedBackgroundColor>
            <gamelistListTextlistUnselectedColor>DCD6B699</gamelistListTextlistUnselectedColor>
